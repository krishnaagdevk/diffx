DIFF_REPO_PATH="/path/to/your/repo"
VITE_API_URL="http://localhost:3001"

# AI Providers — fallback order: Claude → Groq → Gemini
CLAUDE_API_KEY="your-anthropic-api-key"
GROQ_API_KEY="your-groq-api-key"
GEMINI_API_KEY="your-gemini-api-key"

# GitHub token — optional but strongly recommended.
# Without it GitHub rate-limits to 60 req/hr which breaks URL loading.
# Create one at: https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN="your-github-token"
